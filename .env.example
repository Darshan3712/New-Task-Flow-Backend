# ── Copy this file to .env and fill in your values ──────────────────────────

# MongoDB connection string (replace with your Atlas or production URI)
MONGO_URI=mongodb://localhost:27017/Taskflow_New

# Superadmin account created on first startup (change these in production)
SEED_ADMIN_USERNAME=superadmin
SEED_ADMIN_PASSWORD=superadmin123

# Secret key for signing JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret_32_chars_minimum

# Port the backend server will listen on
PORT=5000
